  "keyFeatures": [
    "Real-time expense splitting with multiple methods (equal, percentage, itemized)",
    "Receipt scanning with automatic item extraction",
    "Group management with member balances and ledgers",
    "Google OAuth authentication via Supabase",
    "Transaction analytics and activity feeds",
    "Plaid integration for bank transaction detection"
  ],
  "publicApiSurface": [
    "Group (id, name, emoji, icon, memberCount, balanceCents)",
    "Expense (id, groupId, merchant, amountCents, splitMethod, paidByUserId)",
    "UserProfile (id, email, displayName, avatarUrl)",
    "LedgerEntry (id, groupId, fromUserId, toUserId, amountCents)",
    "Split (id, expenseId, userId, shareCents, isPaid)",
    "GroupRepository (createGroup, getGroups, getGroupById, updateGroup)",
    "ExpensesRepository (createExpense, getExpenses, updateExpense, deleteExpense)",
    "AuthRepository (signIn, signOut, getCurrentUser)"
  ]
